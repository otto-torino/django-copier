name: [[ repo_name ]]-staging

services:
  app:
    container_name: [[ repo_name ]]_staging
    image: [[ repo_name ]]_staging_app
    build:
      context: .
      dockerfile: compose/app/Dockerfile.production
    restart: unless-stopped
    stop_grace_period: 60s
    environment:
      DJANGO_SETTINGS_MODULE: core.settings.production
      SECRET_KEY: ${SECRET_KEY:?Set SECRET_KEY}
      ALLOWED_HOSTS: ${ALLOWED_HOSTS:?Set ALLOWED_HOSTS}
      CSRF_TRUSTED_ORIGINS: ${CSRF_TRUSTED_ORIGINS:?Set CSRF_TRUSTED_ORIGINS}
      SECURE_HSTS_SECONDS: ${SECURE_HSTS_SECONDS:-3600}
      EMAIL_BACKEND: ${EMAIL_BACKEND:-}
      EMAIL_HOST: ${EMAIL_HOST:-}
      EMAIL_PORT: ${EMAIL_PORT:-587}
      EMAIL_HOST_USER: ${EMAIL_HOST_USER:-}
      EMAIL_HOST_PASSWORD: ${EMAIL_HOST_PASSWORD:-}
      EMAIL_USE_TLS: ${EMAIL_USE_TLS:-true}
      EMAIL_USE_SSL: ${EMAIL_USE_SSL:-false}
      EMAIL_TIMEOUT: ${EMAIL_TIMEOUT:-10}
      DEFAULT_FROM_EMAIL: ${DEFAULT_FROM_EMAIL:-[[ email ]]}
      SERVER_EMAIL: ${SERVER_EMAIL:-[[ email ]]}
      LOG_LEVEL: ${LOG_LEVEL:-INFO}
      COOKIERULEZ_WIDGET_CODE: ${COOKIERULEZ_WIDGET_CODE:-}
      DB_HOST: 127.0.0.1
      DB_PORT: ${DB_PORT:-5432}
      DB_NAME: ${DB_NAME:?Set DB_NAME}
      DB_USER: ${DB_USER:?Set DB_USER}
      DB_PASSWORD: ${DB_PASSWORD:?Set DB_PASSWORD}
      RUN_MIGRATIONS: ${RUN_MIGRATIONS:-1}
      COLLECTSTATIC_ON_STARTUP: ${COLLECTSTATIC_ON_STARTUP:-1}
      STATIC_ROOT: /app/static
      MEDIA_ROOT: /app/media
      GUNICORN_WORKERS: ${GUNICORN_WORKERS:-4}
    healthcheck:
      test: ["CMD", "/healthcheck.sh"]
      interval: 10s
      timeout: 5s
      retries: 6
      start_period: 60s
    volumes:
      - [[ repo_name | replace('-', '_') ]]_staging_db:/var/lib/postgresql/data
      - [[ repo_name | replace('-', '_') ]]_staging_media:/app/media
      - [[ repo_name | replace('-', '_') ]]_staging_static:/app/static

  nginx:
    image: nginx:1.28.3-alpine3.23
    container_name: [[ repo_name ]]_staging_nginx
    restart: unless-stopped
    ports:
      - "127.0.0.1:${APP_PORT:?Set APP_PORT}:80"
    volumes:
      - ./compose/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
      - [[ repo_name | replace('-', '_') ]]_staging_media:/app/media:ro
      - [[ repo_name | replace('-', '_') ]]_staging_static:/app/static:ro
    depends_on:
      app:
        condition: service_healthy

volumes:
  [[ repo_name | replace('-', '_') ]]_staging_db:
  [[ repo_name | replace('-', '_') ]]_staging_media:
  [[ repo_name | replace('-', '_') ]]_staging_static:
